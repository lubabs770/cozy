#!/bin/sh
# cozy-session (swww-overlay) — start cozy in --overlay mode, as a transparent
# rain layer above the wallpaper drawn by your swww/hyprpaper daemon.
#
# Reads ~/.config/cozy/cozy.conf, makes a best-effort attempt to point the
# daemon at the same wallpaper (so cozy's refraction matches the background),
# starts `cozy --overlay`, and applies the configured effect/weather once the
# control socket is up. Installed as ~/.local/bin/cozy-session and launched via
# `exec-once` in Hyprland.
#
# All effects (droplet, ripple, snow, clouds) composite transparently in overlay mode:
# cozy stays clear between drops/flakes so the daemon's wallpaper shows through.

set -u

CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/cozy/cozy.conf"
SOCK="${XDG_RUNTIME_DIR:-/tmp}/cozy/cozy.sock"

wallpaper=""
effect=""
wind=""
precip=""

# shellcheck source=/dev/null
[ -r "$CONFIG" ] && . "$CONFIG"

case "$wallpaper" in
    "~/"*) wallpaper="$HOME/${wallpaper#"~/"}" ;;
esac

# Best-effort: ensure the daemon is showing the wallpaper cozy will refract, so
# the two are in sync from the start. (Ongoing changes go through cozy-wall.)
set_daemon_wallpaper() {
    [ -n "$wallpaper" ] && [ -r "$wallpaper" ] || return 0
    if command -v swww >/dev/null 2>&1 && pgrep -x swww-daemon >/dev/null 2>&1; then
        swww img "$wallpaper" >/dev/null 2>&1 || true
    elif command -v hyprctl >/dev/null 2>&1 && pgrep -x hyprpaper >/dev/null 2>&1; then
        hyprctl hyprpaper wallpaper ",$wallpaper" >/dev/null 2>&1 || true
    fi
}
set_daemon_wallpaper

# Launch cozy as a transparent overlay. The wallpaper is the refraction source.
if [ -n "$wallpaper" ] && [ -r "$wallpaper" ]; then
    cozy --overlay --wallpaper "$wallpaper" &
else
    cozy --overlay &
fi
cozy_pid=$!

# Apply effect + weather once the daemon is listening (socket-only commands).
i=0
while [ ! -S "$SOCK" ] && [ "$i" -lt 100 ]; do
    sleep 0.1
    i=$((i + 1))
done

if [ -S "$SOCK" ]; then
    [ -n "$effect" ] && cozy effect "$effect" >/dev/null 2>&1
    if [ -n "$wind" ] || [ -n "$precip" ]; then
        cozy weather --wind "${wind:-0.0}" --precip "${precip:-0.6}" >/dev/null 2>&1
    fi
fi

wait "$cozy_pid"
